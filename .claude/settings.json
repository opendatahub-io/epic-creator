{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/pipeline_state.py post-compact-hook"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python3 scripts/state.py *)",
      "Bash(python3 scripts/pipeline_state.py *)",
      "Bash(python3 scripts/check_decompose_progress.py *)",
      "Bash(python3 scripts/frontmatter.py *)",
      "Bash(python3 scripts/fetch_strategy.py *)",
      "Bash(python3 scripts/attach_decomposition.py *)",
      "Bash(python3 scripts/error_collect.py *)",
      "Bash(python3 scripts/generate_run_report.py *)",
      "Bash(python3 scripts/batch_summary.py *)",
      "Bash(bash scripts/fetch-architecture-context.sh)",
      "Edit(artifacts/**)",
      "Write(artifacts/**)",
      "Edit(tmp/**)",
      "Write(tmp/**)",
      "Read(artifacts/**)",
      "Read(tmp/**)",
      "Read(.context/**)",
      "Read(docs/**)"
    ]
  }
}
